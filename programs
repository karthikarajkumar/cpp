 22)You are given a positive integer N.
 In one step, you can do any of the following:
 1. Subtract 1 from N
 2. If N is divisible by 2, divide N by 2
 3. If N is divisible by 3, divide N by 3
 Find the minimum number of steps required to reduce N to 1.
 Input Format:- A single integer N (1 <= N <= 10^6)
 Output Format:- A single integer - the minimum steps to reduce N to 1.
 Example:
 Input:
 10
 Output:
 3
 Explanation:
 10 -> 9 -> 3 -> 1 (3 steps)
 
#include <iostream>
#include <climits>
#include <algorithm>
using namespace std;

int minsteps(int n)
{
  if (n==1)
    return 0;
  int ans1=minsteps(n-1);
  int ans2=INT_MAX;
  int ans3=INT_MAX;
  if (n%2==0)
    ans2= minsteps(n/2);
  if (n%3==0)
    ans3= minsteps(n/3);
  return 1+min({ans1,ans2,ans3});
}

int main()
{
  int n;
  cin>>n;
  cout<<minsteps(n);
}

