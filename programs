     a--;
  int l=0;
  while (a>=0 && s[a]!=' ')
  {
     l++;
     a--;
  }
  return l;
}

string lastword(string s)
{
  if (s.empty())
     return " ";
  int a=s.length()-1;
  while (a>=0 && s[a]==' ')
     a--;
  string lastw="";
  while (a>=0 && s[a]!=' ')
  {
     lastw=s[a]+lastw;
     a--;
  }
  return lastw;
}

